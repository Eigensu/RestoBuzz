{
  "name": "whatsapp-bulk-sender",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "dev:backend": "pnpm --filter backend run dev",
    "dev:worker": "pnpm --filter backend run worker",
    "dev:beat": "pnpm --filter backend run beat",
    "dev:flower": "pnpm --filter backend run flower",
    "setup:backend": "pnpm --filter backend run setup",
    "init:db": "pnpm --filter backend run init:db"
  },
  "devDependencies": {
    "turbo": "^2.8.20"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  }
}
