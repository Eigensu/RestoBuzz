# ─────────────────────────────────────────────────────────────────────────────
# ROOT .env.example — copy to .env and fill in real values
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017/whatsapp_bulk

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_64_char_random_hex_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Meta Cloud API ────────────────────────────────────────────────────────────
META_API_VERSION=v21.0
META_PRIMARY_PHONE_ID=your_primary_phone_number_id
META_PRIMARY_ACCESS_TOKEN=your_primary_access_token
META_FALLBACK_PHONE_ID=your_fallback_phone_number_id
META_FALLBACK_ACCESS_TOKEN=your_fallback_access_token
META_WEBHOOK_VERIFY_TOKEN=your_random_verify_token
META_WEBHOOK_SECRET=your_app_secret_for_hmac

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_CONCURRENCY=4
RATE_LIMIT_MPS=80

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=DishPatch

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (add your ngrok/production URL here)
CORS_ORIGINS=http://localhost:3000

# ── WhatsApp Quick-Reply Auto-Response ───────────────────────────────────────
# The link automatically sent when a user taps the "Get the benefits" button
BENEFITS_LINK=https://yourdomain.com/benefits

# ── ReserveGo Upload Portal ───────────────────────────────────────────────────
# Credentials for the /reservego upload page (set these from your admin panel)
RESERVEGO_USER=reservego
RESERVEGO_PASSWORD=change_me_strong_password

# ── Resend (Email Campaigns) ──────────────────────────────────────────────────
# API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Webhook signing secret from https://resend.com/webhooks (svix-based)
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Verified sender address configured in your Resend domain
RESEND_FROM_EMAIL=noreply@yourdomain.com
# Max emails per second sent to Resend (stay within your plan limits)
RESEND_RATE_LIMIT=10
