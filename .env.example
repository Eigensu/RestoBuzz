# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://mongo:27017/whatsapp_bulk

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_64_char_random_hex_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Meta Cloud API ────────────────────────────────────────────────────────────
META_API_VERSION=v21.0
META_PRIMARY_PHONE_ID=your_primary_phone_number_id
META_PRIMARY_ACCESS_TOKEN=your_primary_access_token
META_FALLBACK_PHONE_ID=your_fallback_phone_number_id
META_FALLBACK_ACCESS_TOKEN=your_fallback_access_token
META_WEBHOOK_VERIFY_TOKEN=your_random_verify_token
META_WEBHOOK_SECRET=your_app_secret_for_hmac

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_CONCURRENCY=4
RATE_LIMIT_MPS=80

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=WA Bulk Sender
